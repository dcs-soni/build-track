# =============================================================================
# BuildTrack Production Environment Template
# =============================================================================
# Copy this file to .env.production and fill in the values
# NEVER commit .env.production to version control!
# =============================================================================

# Database (Required)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
POSTGRES_DB=buildtrack

# JWT (Required)
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS (Required)
CORS_ORIGIN=https://your-domain.com

# Docker Registry
DOCKER_REGISTRY=ghcr.io/your-username

# Docker Images (set by CI/CD or deploy script)
API_IMAGE=ghcr.io/your-username/buildtrack/api:latest
WEB_IMAGE=ghcr.io/your-username/buildtrack/web:latest

# Turbo Remote Caching (Optional - speeds up CI)
# TURBO_TOKEN=your-turbo-token
# TURBO_TEAM=your-team-name
