# =============================================================================
# BuildTrack - Docker Ignore File
# =============================================================================
# Reduces Docker build context size for faster builds

# Dependencies
node_modules
**/node_modules

# Build outputs
dist
**/dist
.turbo
**/.turbo
coverage
**/coverage

# Git
.git
.gitignore

# IDE
.idea
.vscode
*.swp
*.swo

# Environment files (will be injected at runtime)
.env
.env.*
!.env.example

# Logs
*.log
logs

# OS files
.DS_Store
Thumbs.db

# Testing
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__
**/__tests__

# Documentation
*.md
!README.md
docs

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD
.github

# Misc
*.tsbuildinfo
.eslintcache
.turbo
