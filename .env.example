# =============================================================================
# BuildTrack — Root Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# This single .env is the source of truth for ALL packages in the monorepo.
# Scripts use dotenv-cli to load it from the root. Never duplicate env files
# into individual packages.
# =============================================================================

# Database (Required — used by @buildtrack/database and @buildtrack/api)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/buildtrack?schema=public"

# API Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS (must match the web app's dev server URL)
CORS_ORIGIN=http://localhost:5173

# =============================================================================
# Web App (Optional — Vite reads VITE_* vars automatically)
# =============================================================================
# VITE_API_URL=http://localhost:4000

# =============================================================================
# Docker & Deployment (Optional — only needed for production)
# =============================================================================
# DOCKER_REGISTRY=ghcr.io/your-username

# Turbo Remote Caching (Optional — speeds up CI)
# TURBO_TOKEN=your-turbo-token
# TURBO_TEAM=your-team-name
