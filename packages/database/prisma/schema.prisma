// Multi-tenant Real Estate & Construction Management Platform Schema
// Updated with 10 new features

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// TENANTS & USERS
// ============================================================================

model Tenant {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  plan      String   @default("free") @db.VarChar(50)
  settings  Json     @default("{}")
  logoUrl   String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships    TenantMembership[]
  projects       Project[]
  subcontractors Subcontractor[]
  invitations    Invitation[]
  activityLogs   ActivityLog[]
  equipment      Equipment[]
  notificationPreferences NotificationPreference[]
  notifications   Notification[]

  @@map("tenants")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique @db.VarChar(255)
  passwordHash String?   @db.VarChar(255)
  name         String    @db.VarChar(255)
  avatarUrl    String?   @db.VarChar(500)
  phone        String?   @db.VarChar(50)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  memberships      TenantMembership[]
  createdProjects  Project[]          @relation("ProjectCreator")
  assignedTasks    Task[]             @relation("TaskAssignee")
  dailyReports     DailyReport[]
  documents        Document[]
  notifications    Notification[]
  uploadedPhotos   Photo[]
  createdExpenses  Expense[]
  activityLogs     ActivityLog[]
  sentInvitations  Invitation[]

  // RFI Relations
  assignedRFIs     RFI[]              @relation("RFIAssignee")
  answeredRFIs     RFI[]              @relation("RFIAnsweredBy")
  createdRFIs      RFI[]              @relation("RFICreator")
  rfiResponses     RFIResponse[]
  rfiAttachments   RFIAttachment[]
  rfiDistributions RFIDistribution[]

  // Equipment Relations
  equipmentAssignedTo   EquipmentAssignment[] @relation("EquipmentAssignedTo")
  equipmentAssignedBy   EquipmentAssignment[] @relation("EquipmentAssignedBy")
  equipmentCheckedInBy  EquipmentAssignment[] @relation("EquipmentCheckedInBy")
  equipmentMaintenance  EquipmentMaintenance[]
  equipmentDocuments    EquipmentDocument[]

  // Project Updates & Notification Preferences
  projectUpdates           ProjectUpdate[]
  notificationPreferences  NotificationPreference[]

  // Inspection Relations
  inspectionsAsInspector  Inspection[]     @relation("InspectionInspector")
  createdInspections      Inspection[]     @relation("InspectionCreator")

  // Punch List Relations
  assignedPunchItems      PunchListItem[]  @relation("PunchItemAssignee")
  verifiedPunchItems      PunchListItem[]  @relation("PunchItemVerifier")
  createdPunchItems       PunchListItem[]  @relation("PunchItemCreator")

  // Safety Incident Relations
  reportedIncidents       SafetyIncident[] @relation("IncidentReporter")

  // Change Order Relations
  requestedChangeOrders   ChangeOrder[]    @relation("ChangeOrderRequester")
  approvedChangeOrders    ChangeOrder[]    @relation("ChangeOrderApprover")

  @@map("users")
}

model TenantMembership {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String
  role        String   @db.VarChar(50) // owner, admin, manager, member, viewer, client
  permissions Json     @default("[]")
  joinedAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_memberships")
}

// ============================================================================
// TEAM INVITATIONS (Feature 6)
// ============================================================================

model Invitation {
  id         String    @id @default(uuid())
  tenantId   String
  email      String    @db.VarChar(255)
  role       String    @db.VarChar(50)
  token      String    @unique @db.VarChar(100)
  expiresAt  DateTime
  acceptedAt DateTime?
  invitedBy  String
  createdAt  DateTime  @default(now())

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inviter User   @relation(fields: [invitedBy], references: [id])

  @@index([tenantId])
  @@index([token])
  @@map("invitations")
}

// ============================================================================
// PROJECTS
// ============================================================================

model Project {
  id          String   @id @default(uuid())
  tenantId    String
  name        String   @db.VarChar(255)
  description String?  @db.Text
  projectType String?  @db.VarChar(50)
  status      String   @default("planning") @db.VarChar(50)

  address    String? @db.Text
  city       String? @db.VarChar(100)
  state      String? @db.VarChar(100)
  postalCode String? @db.VarChar(20)
  country    String? @db.VarChar(100)
  latitude   Float?
  longitude  Float?

  startDate    DateTime? @db.Date
  estimatedEnd DateTime? @db.Date
  actualEnd    DateTime? @db.Date

  budget   Decimal? @db.Decimal(15, 2)
  currency String   @default("USD") @db.VarChar(3)

  // Client portal settings
  clientAccessEnabled Boolean @default(false)
  clientAccessToken   String? @unique @db.VarChar(100)

  coverImage String?  @db.VarChar(500)
  createdBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator      User?         @relation("ProjectCreator", fields: [createdBy], references: [id])
  budgetItems  BudgetItem[]
  dailyReports DailyReport[]
  tasks        Task[]
  documents    Document[]
  permits      Permit[]
  photos       Photo[]
  expenses     Expense[]
  activityLogs ActivityLog[]
  rfis         RFI[]
  currentEquipment   Equipment[]           @relation("CurrentEquipment")
  equipmentAssignments EquipmentAssignment[]
  updates      ProjectUpdate[]
  inspections    Inspection[]
  punchListItems PunchListItem[]
  safetyIncidents SafetyIncident[]
  changeOrders   ChangeOrder[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([status])
  @@map("projects")
}

// ============================================================================
// PROJECT UPDATES (Communication)
// ============================================================================

model ProjectUpdate {
  id        String   @id @default(uuid())
  tenantId  String
  projectId String
  title     String   @db.VarChar(255)
  body      String   @db.Text
  audience  String   @default("internal") @db.VarChar(20) // internal, client
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId, tenantId], references: [id, tenantId], onDelete: Cascade)
  author  User    @relation(fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([projectId, tenantId])
  @@index([audience])
  @@map("project_updates")
}

// ============================================================================
// BUDGET & COSTS (Feature 1: Budget Analytics)
// ============================================================================

model BudgetItem {
  id            String    @id @default(uuid())
  tenantId      String
  projectId     String
  category      String    @db.VarChar(100)
  description   String    @db.Text
  estimatedCost Decimal   @db.Decimal(15, 2)
  actualCost    Decimal   @default(0) @db.Decimal(15, 2)
  status        String    @default("pending") @db.VarChar(50)
  notes         String?   @db.Text
  dueDate       DateTime? @db.Date
  
  // Alert thresholds
  alertThreshold Decimal? @db.Decimal(5, 2) // Percentage (e.g., 80% = alert when 80% spent)
  alertSent      Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  expenses         Expense[]
  changeOrderItems ChangeOrderItem[]

  @@index([tenantId])
  @@index([projectId])
  @@index([projectId, tenantId])
  @@index([category])
  @@map("budget_items")
}

// ============================================================================
// EXPENSE TRACKING (Feature 8)
// ============================================================================

model Expense {
  id           String   @id @default(uuid())
  tenantId     String
  projectId    String
  budgetItemId String?
  amount       Decimal  @db.Decimal(15, 2)
  currency     String   @default("USD") @db.VarChar(3)
  vendor       String?  @db.VarChar(255)
  description  String   @db.Text
  category     String   @db.VarChar(50)
  receiptUrl   String?  @db.VarChar(500)
  expenseDate  DateTime @db.Date
  
  // Approval workflow
  status       String   @default("pending") @db.VarChar(50) // pending, approved, rejected
  approvedBy   String?
  approvedAt   DateTime?
  
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetItem BudgetItem? @relation(fields: [budgetItemId], references: [id])
  creator    User?       @relation(fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([projectId, tenantId])
  @@index([budgetItemId])
  @@index([expenseDate])
  @@map("expenses")
}

// ============================================================================
// DAILY REPORTS (Feature 2)
// ============================================================================

model DailyReport {
  id           String   @id @default(uuid())
  tenantId     String
  projectId    String
  reportDate   DateTime @db.Date
  weather      String?  @db.VarChar(50)
  temperature  Int?
  humidity     Int?
  workSummary  String?  @db.Text
  issues       String?  @db.Text
  safetyNotes  String?  @db.Text
  workersCount Int?
  
  // Equipment and materials
  equipmentUsed String? @db.Text
  materialsUsed String? @db.Text
  
  // Sign-off
  supervisorSignOff Boolean   @default(false)
  signedOffBy       String?
  signedOffAt       DateTime?
  
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId, tenantId], references: [id, tenantId], onDelete: Cascade)
  author  User?   @relation(fields: [createdBy], references: [id])
  photos  Photo[]

  @@unique([projectId, reportDate])
  @@index([tenantId])
  @@index([projectId])
  @@index([projectId, tenantId])
  @@index([reportDate])
  @@map("daily_reports")
}

// ============================================================================
// PHOTO DOCUMENTATION (Feature 5)
// ============================================================================

model Photo {
  id           String   @id @default(uuid())
  tenantId     String
  projectId    String
  reportId     String?
  url          String   @db.VarChar(500)
  thumbnailUrl String?  @db.VarChar(500)
  caption      String?  @db.Text
  category     String?  @db.VarChar(50) // progress, issue, safety, completion, before, after
  location     String?  @db.VarChar(255) // Where in the project
  
  // Annotations stored as JSON
  annotations  Json     @default("[]")
  
  takenAt    DateTime @default(now())
  uploadedBy String?
  createdAt  DateTime @default(now())

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dailyReport DailyReport? @relation(fields: [reportId], references: [id])
  uploader    User?        @relation(fields: [uploadedBy], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([projectId, tenantId])
  @@index([reportId])
  @@index([category])
  @@map("photos")
}

// ============================================================================
// TASKS (Feature 10: Timeline/Gantt)
// ============================================================================

model Task {
  id              String    @id @default(uuid())
  tenantId        String
  projectId       String
  parentId        String?
  title           String    @db.VarChar(255)
  description     String?   @db.Text
  status          String    @default("pending") @db.VarChar(50)
  priority        String    @default("medium") @db.VarChar(20)
  startDate       DateTime? @db.Date
  dueDate         DateTime? @db.Date
  completedAt     DateTime?
  estimatedHours  Float?
  actualHours     Float?
  assignedTo      String?
  subcontractorId String?
  sortOrder       Int       @default(0)
  
  // Dependencies for Gantt (Feature 10)
  dependsOn       String[]  @default([]) // Array of task IDs this task depends on
  
  // Progress tracking
  progressPercent Int       @default(0) // 0-100
  
  // Color coding for timeline
  color           String?   @db.VarChar(7) // Hex color
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent        Task?          @relation("TaskHierarchy", fields: [parentId], references: [id])
  subtasks      Task[]         @relation("TaskHierarchy")
  assignee      User?          @relation("TaskAssignee", fields: [assignedTo], references: [id])
  subcontractor Subcontractor? @relation(fields: [subcontractorId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([projectId, tenantId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}

// ============================================================================
// SUBCONTRACTORS (Feature 3)
// ============================================================================

model Subcontractor {
  id              String    @id @default(uuid())
  tenantId        String
  companyName     String    @db.VarChar(255)
  contactName     String?   @db.VarChar(255)
  email           String?   @db.VarChar(255)
  phone           String?   @db.VarChar(50)
  address         String?   @db.Text
  trade           String?   @db.VarChar(100)
  licenseNumber   String?   @db.VarChar(100)
  licenseExpiry   DateTime? @db.Date
  insuranceNumber String?   @db.VarChar(100)
  insuranceExpiry DateTime? @db.Date
  
  // Performance tracking
  rating          Decimal?  @db.Decimal(3, 2) // 0.00 - 5.00
  completedJobs   Int       @default(0)
  onTimePercent   Decimal?  @db.Decimal(5, 2)
  
  // Portal access
  portalSecretHash String?  @db.VarChar(255) // Argon2 hash of the portal access secret

  // Documents
  w9Url           String?   @db.VarChar(500)
  insuranceCertUrl String?  @db.VarChar(500)
  
  notes    String?  @db.Text
  isActive Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@index([tenantId])
  @@index([trade])
  @@index([isActive])
  @@unique([tenantId, email])
  @@map("subcontractors")
}

// ============================================================================
// DOCUMENTS
// ============================================================================

model Document {
  id          String   @id @default(uuid())
  tenantId    String
  projectId   String?
  folderId    String?
  name        String   @db.VarChar(255)
  type        String   @db.VarChar(50)
  mimeType    String?  @db.VarChar(100)
  sizeBytes   BigInt?
  storagePath String?  @db.VarChar(500)
  version     Int      @default(1)
  tags        String[] @default([])
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   Document?  @relation("DocumentHierarchy", fields: [folderId], references: [id])
  children Document[] @relation("DocumentHierarchy")
  uploader User?      @relation(fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([projectId, tenantId])
  @@map("documents")
}

// ============================================================================
// PERMITS (Feature 4)
// ============================================================================

model Permit {
  id            String    @id @default(uuid())
  tenantId      String
  projectId     String
  permitType    String    @db.VarChar(100)
  permitNumber  String?   @db.VarChar(100)
  issuingAgency String?   @db.VarChar(255)
  status        String    @default("pending") @db.VarChar(50)
  
  // Timeline
  submittedAt   DateTime? @db.Date
  reviewStarted DateTime?
  approvedAt    DateTime? @db.Date
  expiresAt     DateTime? @db.Date
  
  fees          Decimal?  @db.Decimal(10, 2)
  notes         String?   @db.Text
  
  // Document references
  applicationUrl String?   @db.VarChar(500)
  approvalUrl    String?   @db.VarChar(500)
  
  // Reminders
  reminderDays   Int       @default(30) // Days before expiry to remind
  reminderSent   Boolean   @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@index([tenantId])
  @@index([projectId])
  @@index([projectId, tenantId])
  @@index([status])
  @@index([expiresAt])
  @@map("permits")
}

// ============================================================================
// RFI - REQUEST FOR INFORMATION (Industry Standard)
// ============================================================================

model RFI {
  id            String    @id @default(uuid())
  tenantId      String
  projectId     String
  
  // RFI Identification
  rfiNumber     String    @db.VarChar(50)  // Auto-generated: PROJ-RFI-001
  subject       String    @db.VarChar(255)
  
  // Question Details
  question      String    @db.Text
  suggestedAnswer String? @db.Text  // Contractor's proposed solution
  
  // Document References
  drawingRef    String?   @db.VarChar(255)  // Drawing number/sheet reference
  specSection   String?   @db.VarChar(100)  // Specification section reference
  location      String?   @db.VarChar(255)  // Physical location on site
  
  // Workflow Status
  status        String    @default("draft") @db.VarChar(50)
  // Values: draft, open, under_review, answered, closed, void
  priority      String    @default("normal") @db.VarChar(20)
  // Values: low, normal, high, urgent
  
  // Assignment & Ball-in-Court
  assignedToId  String?   // Who needs to respond
  ballInCourt   String    @default("contractor") @db.VarChar(50)
  // Values: contractor, architect, engineer, owner, consultant
  
  // Key Dates
  dateSubmitted DateTime?
  dateRequired  DateTime  @db.Date  // Response needed by this date
  dateAnswered  DateTime?
  dateClosed    DateTime?
  
  // Impact Assessment (Critical for construction)
  costImpact      Boolean   @default(false)
  scheduleImpact  Boolean   @default(false)
  costAmount      Decimal?  @db.Decimal(15, 2)  // Estimated cost impact
  scheduleDays    Int?      // Estimated days of delay
  impactNotes     String?   @db.Text
  
  // Official Answer (final response)
  officialAnswer  String?   @db.Text
  answeredById    String?
  
  // Metadata
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo    User?         @relation("RFIAssignee", fields: [assignedToId], references: [id])
  answeredBy    User?         @relation("RFIAnsweredBy", fields: [answeredById], references: [id])
  creator       User          @relation("RFICreator", fields: [createdBy], references: [id])
  responses     RFIResponse[]
  attachments   RFIAttachment[]
  distributions RFIDistribution[]

  @@unique([projectId, rfiNumber])
  @@index([tenantId])
  @@index([projectId])
  @@index([projectId, tenantId])
  @@index([status])
  @@index([ballInCourt])
  @@index([dateRequired])
  @@index([assignedToId])
  @@map("rfis")
}

model RFIResponse {
  id          String    @id @default(uuid())
  rfiId       String
  responderId String
  response    String    @db.Text
  isOfficial  Boolean   @default(false)  // Official answer vs. discussion comment
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  rfi         RFI       @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  responder   User      @relation(fields: [responderId], references: [id])

  @@index([rfiId])
  @@index([responderId])
  @@map("rfi_responses")
}

model RFIAttachment {
  id          String    @id @default(uuid())
  rfiId       String
  fileName    String    @db.VarChar(255)
  fileUrl     String    @db.VarChar(500)
  fileType    String    @db.VarChar(100)  // MIME type
  fileSize    Int       // Size in bytes
  description String?   @db.VarChar(500)
  uploadedBy  String
  createdAt   DateTime  @default(now())
  
  rfi         RFI       @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  uploader    User      @relation(fields: [uploadedBy], references: [id])

  @@index([rfiId])
  @@map("rfi_attachments")
}

model RFIDistribution {
  id         String    @id @default(uuid())
  rfiId      String
  userId     String
  notifiedAt DateTime?  // When notification was sent
  viewedAt   DateTime?  // When user viewed the RFI
  
  rfi        RFI       @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id])

  @@unique([rfiId, userId])
  @@index([rfiId])
  @@index([userId])
  @@map("rfi_distributions")
}

// ============================================================================
// EQUIPMENT/ASSET TRACKING (Enterprise)
// ============================================================================

model Equipment {
  id            String    @id @default(uuid())
  tenantId      String
  
  // Identification
  assetTag      String    @db.VarChar(100)  // Unique asset ID/barcode
  name          String    @db.VarChar(255)
  description   String?   @db.Text
  category      String    @db.VarChar(50)   // tool, vehicle, heavy_equipment, safety, other
  subcategory   String?   @db.VarChar(100)
  
  // Manufacturer Details
  manufacturer  String?   @db.VarChar(255)
  model         String?   @db.VarChar(255)
  serialNumber  String?   @db.VarChar(255)
  
  // Purchase/Financial
  purchaseDate    DateTime? @db.Date
  purchasePrice   Decimal?  @db.Decimal(15, 2)
  warrantyExpiry  DateTime? @db.Date
  depreciationRate Decimal? @db.Decimal(5, 2)  // Annual percentage
  currentValue    Decimal?  @db.Decimal(15, 2) // Calculated value
  
  // Status & Location
  status          String    @default("available") @db.VarChar(50)
  // Values: available, checked_out, maintenance, retired, lost
  condition       String    @default("good") @db.VarChar(50)
  // Values: excellent, good, fair, poor, needs_repair
  currentProjectId String?
  storageLocation String?   @db.VarChar(255)
  
  // Maintenance Config
  maintenanceIntervalDays Int?
  lastMaintenanceDate     DateTime?
  nextMaintenanceDate     DateTime?
  meterReading            Decimal?  @db.Decimal(12, 2) // Hours/miles/etc
  meterUnit               String?   @db.VarChar(20)    // hours, miles, km
  
  // Media
  imageUrl      String?   @db.VarChar(500)
  qrCodeData    String?   @db.VarChar(500)  // QR code content
  
  // Metadata
  notes         String?   @db.Text
  customFields  Json      @default("{}")  // Flexible custom attributes
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currentProject Project? @relation("CurrentEquipment", fields: [currentProjectId], references: [id])
  assignments   EquipmentAssignment[]
  maintenanceRecords EquipmentMaintenance[]
  documents     EquipmentDocument[]

  @@unique([tenantId, assetTag])
  @@index([tenantId])
  @@index([category])
  @@index([status])
  @@index([currentProjectId])
  @@index([nextMaintenanceDate])
  @@map("equipment")
}

model EquipmentAssignment {
  id            String    @id @default(uuid())
  tenantId      String
  equipmentId   String
  projectId     String?
  
  // Assignment Details
  assignedToId  String    // User who has it
  assignedById  String    // User who assigned it
  purpose       String?   @db.VarChar(500)
  
  // Check-out
  checkedOutAt  DateTime  @default(now())
  expectedReturnAt DateTime?
  
  // Check-in
  checkedInAt   DateTime?
  checkedInById String?
  
  // Condition Assessment
  conditionOut  String    @db.VarChar(50)  // excellent, good, fair, poor
  conditionIn   String?   @db.VarChar(50)
  meterOut      Decimal?  @db.Decimal(12, 2)  // Meter reading at checkout
  meterIn       Decimal?  @db.Decimal(12, 2)  // Meter reading at checkin
  notesOut      String?   @db.Text
  notesIn       String?   @db.Text
  
  // Digital Signatures/Photos (URLs)
  signatureOutUrl String? @db.VarChar(500)
  signatureInUrl  String? @db.VarChar(500)
  photoOutUrl     String? @db.VarChar(500)
  photoInUrl      String? @db.VarChar(500)
  
  createdAt     DateTime  @default(now())

  equipment     Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  project       Project?  @relation(fields: [projectId], references: [id])
  assignedTo    User      @relation("EquipmentAssignedTo", fields: [assignedToId], references: [id])
  assignedBy    User      @relation("EquipmentAssignedBy", fields: [assignedById], references: [id])
  checkedInBy   User?     @relation("EquipmentCheckedInBy", fields: [checkedInById], references: [id])

  @@index([tenantId])
  @@index([equipmentId])
  @@index([projectId])
  @@index([projectId, tenantId])
  @@index([assignedToId])
  @@index([checkedOutAt])
  @@index([checkedInAt])
  @@map("equipment_assignments")
}

model EquipmentMaintenance {
  id            String    @id @default(uuid())
  tenantId      String
  equipmentId   String
  
  // Maintenance Type
  type          String    @db.VarChar(50)
  // Values: scheduled, preventive, repair, inspection, calibration, emergency
  title         String    @db.VarChar(255)
  description   String?   @db.Text
  priority      String    @default("normal") @db.VarChar(20)
  
  // Scheduling
  scheduledDate DateTime  @db.Date
  dueDate       DateTime? @db.Date  // For window-based scheduling
  completedDate DateTime?
  status        String    @default("scheduled") @db.VarChar(50)
  // Values: scheduled, in_progress, completed, cancelled, overdue
  
  // Work Details
  performedById String?   // Internal technician
  vendor        String?   @db.VarChar(255)  // External service provider
  workOrderNumber String? @db.VarChar(100)
  
  // Cost Tracking
  laborHours    Decimal?  @db.Decimal(5, 2)
  partsCost     Decimal?  @db.Decimal(10, 2)
  laborCost     Decimal?  @db.Decimal(10, 2)
  otherCost     Decimal?  @db.Decimal(10, 2)
  totalCost     Decimal?  @db.Decimal(10, 2)
  
  // Meter Reading
  meterReading  Decimal?  @db.Decimal(12, 2)
  
  // Documentation
  findings      String?   @db.Text
  actionsTaken  String?   @db.Text
  partsUsed     Json      @default("[]")  // Array of {name, quantity, cost}
  receiptUrl    String?   @db.VarChar(500)
  
  // Follow-up
  followUpRequired Boolean @default(false)
  followUpNotes   String?  @db.Text
  nextScheduledDate DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  equipment     Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  performedBy   User?     @relation(fields: [performedById], references: [id])

  @@index([tenantId])
  @@index([equipmentId])
  @@index([scheduledDate])
  @@index([status])
  @@index([type])
  @@map("equipment_maintenance")
}

model EquipmentDocument {
  id            String    @id @default(uuid())
  equipmentId   String
  name          String    @db.VarChar(255)
  type          String    @db.VarChar(50)
  // Values: manual, warranty, certificate, inspection_report, invoice, insurance, license
  fileUrl       String    @db.VarChar(500)
  fileSize      Int?      // Size in bytes
  mimeType      String?   @db.VarChar(100)
  expiresAt     DateTime? // For certificates, warranties, etc.
  reminderDays  Int?      // Days before expiry to remind
  uploadedById  String
  createdAt     DateTime  @default(now())

  equipment     Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  uploadedBy    User      @relation(fields: [uploadedById], references: [id])

  @@index([equipmentId])
  @@index([type])
  @@index([expiresAt])
  @@map("equipment_documents")
}

// ============================================================================
// ACTIVITY TIMELINE (Feature 7)
// ============================================================================

model ActivityLog {
  id         String   @id @default(uuid())
  tenantId   String
  projectId  String?
  userId     String
  action     String   @db.VarChar(50) // created, updated, deleted, completed, approved, rejected
  entityType String   @db.VarChar(50) // task, budget_item, expense, daily_report, permit, etc.
  entityId   String   @db.VarChar(100)
  entityName String?  @db.VarChar(255) // Human readable name
  changes    Json     @default("{}") // { field: { old: value, new: value } }
  metadata   Json     @default("{}") // Additional context
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.VarChar(500)
  createdAt  DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([projectId])
  @@index([projectId, tenantId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id        String    @id @default(uuid())
  tenantId  String
  userId    String
  type      String    @db.VarChar(50)
  title     String    @db.VarChar(255)
  message   String    @db.Text
  link      String?   @db.VarChar(500)
  
  // Priority for filtering
  priority  String    @default("normal") @db.VarChar(20) // low, normal, high, urgent
  
  isRead    Boolean   @default(false)
  readAt    DateTime?
  
  // Email delivery tracking
  emailSent Boolean   @default(false)
  emailSentAt DateTime?
  
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String

  inAppEnabled  Boolean @default(true)
  emailEnabled  Boolean @default(false)
  digestFrequency String @default("immediate") @db.VarChar(20) // immediate, daily, weekly, none

  notifyTaskAssigned   Boolean @default(true)
  notifyRfiAssigned    Boolean @default(true)
  notifyRfiResponse    Boolean @default(true)
  notifyProjectUpdates Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("notification_preferences")
}

// ============================================================================
// AUTH
// ============================================================================

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique @db.VarChar(500)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================================================
// INSPECTIONS
// ============================================================================

model Inspection {
  id            String    @id @default(uuid())
  tenantId      String
  projectId     String

  // Identification
  inspectionNumber String  @db.VarChar(50)  // Auto-generated: PROJ-INS-001
  inspectionType   String  @db.VarChar(100) // structural, electrical, plumbing, fire_safety, hvac, roofing, foundation, final, other
  title            String  @db.VarChar(255)
  description      String? @db.Text

  // Status & Result
  status           String  @default("scheduled") @db.VarChar(50)
  // Values: scheduled, in_progress, passed, failed, needs_reinspection, cancelled
  result           String? @db.VarChar(50)  // pass, fail, conditional_pass

  // Assignment
  inspectorId      String?   // Internal inspector user
  inspectorName    String?   @db.VarChar(255) // External inspector name
  inspectorCompany String?   @db.VarChar(255) // External inspector company

  // Scheduling
  scheduledDate    DateTime  @db.Date
  scheduledTime    String?   @db.VarChar(20)  // e.g., "09:00 AM"
  completedDate    DateTime?

  // Location & Reference
  location         String?   @db.VarChar(255)
  drawingRef       String?   @db.VarChar(255)
  specSection      String?   @db.VarChar(100)

  // Findings
  findings         String?   @db.Text
  deficiencies     String?   @db.Text
  correctiveActions String?  @db.Text

  // Cost & Schedule Impact
  costImpact       Boolean   @default(false)
  scheduleImpact   Boolean   @default(false)
  estimatedCost    Decimal?  @db.Decimal(15, 2)
  delayDays        Int?

  // Documents
  reportUrl        String?   @db.VarChar(500)
  photoUrls        String[]  @default([])

  // Metadata
  createdBy        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inspector        User?     @relation("InspectionInspector", fields: [inspectorId], references: [id])
  creator          User      @relation("InspectionCreator", fields: [createdBy], references: [id])

  @@unique([projectId, inspectionNumber])
  @@index([tenantId])
  @@index([projectId])
  @@index([projectId, tenantId])
  @@index([status])
  @@index([scheduledDate])
  @@index([inspectionType])
  @@map("inspections")
}

// ============================================================================
// PUNCH LIST (SNAG LIST)
// ============================================================================

model PunchListItem {
  id            String    @id @default(uuid())
  tenantId      String
  projectId     String

  // Identification
  itemNumber    String    @db.VarChar(50)  // Auto-generated: PROJ-PL-001
  title         String    @db.VarChar(255)
  description   String?   @db.Text

  // Classification
  category      String    @default("general") @db.VarChar(50)
  // Values: general, electrical, plumbing, hvac, structural, finish, landscape, other
  priority      String    @default("medium") @db.VarChar(20)
  // Values: low, medium, high, critical
  status        String    @default("open") @db.VarChar(50)
  // Values: open, in_progress, resolved, verified, wont_fix

  // Location & Reference
  location      String?   @db.VarChar(255)
  floor         String?   @db.VarChar(50)
  room          String?   @db.VarChar(100)
  drawingRef    String?   @db.VarChar(255)

  // Assignment
  assignedToId  String?   // Responsible user
  dueDate       DateTime? @db.Date

  // Resolution
  resolution    String?   @db.Text
  resolvedAt    DateTime?
  verifiedById  String?   // Different user who verified the fix
  verifiedAt    DateTime?

  // Documentation
  photoUrls     String[]  @default([])
  notes         String?   @db.Text

  // Metadata
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo    User?     @relation("PunchItemAssignee", fields: [assignedToId], references: [id])
  verifiedBy    User?     @relation("PunchItemVerifier", fields: [verifiedById], references: [id])
  creator       User      @relation("PunchItemCreator", fields: [createdBy], references: [id])

  @@unique([projectId, itemNumber])
  @@index([tenantId])
  @@index([projectId])
  @@index([projectId, tenantId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([dueDate])
  @@map("punch_list_items")
}

// ============================================================================
// SAFETY INCIDENTS
// ============================================================================

model SafetyIncident {
  id            String    @id @default(uuid())
  tenantId      String
  projectId     String

  // Identification
  incidentNumber String   @db.VarChar(50)  // Auto-generated: PROJ-SI-001
  title          String   @db.VarChar(255)
  description    String   @db.Text

  // Classification
  incidentType   String   @db.VarChar(50)
  // Values: near_miss, first_aid, recordable, lost_time, property_damage, environmental
  severity       String   @default("low") @db.VarChar(20)
  // Values: low, medium, high, critical
  status         String   @default("reported") @db.VarChar(50)
  // Values: reported, investigating, resolved, closed

  // Incident Details
  incidentDate   DateTime @db.Date
  incidentTime   String?  @db.VarChar(20)
  location       String?  @db.VarChar(255)
  weather        String?  @db.VarChar(50)

  // People Involved
  injuredParty   String?  @db.VarChar(255)
  witnesses      String?  @db.Text
  workersOnSite  Int?

  // Root Cause & Corrective Actions
  rootCause      String?  @db.Text
  immediateAction String? @db.Text
  correctiveAction String? @db.Text
  preventiveAction String? @db.Text

  // Investigation
  investigatedAt   DateTime?
  investigationNotes String? @db.Text

  // Resolution
  resolvedAt       DateTime?
  closedAt         DateTime?
  closureNotes     String?  @db.Text

  // OSHA Recordable
  oshaRecordable   Boolean  @default(false)
  daysLost         Int      @default(0)
  restrictedDays   Int      @default(0)

  // Documentation
  photoUrls        String[] @default([])
  reportUrl        String?  @db.VarChar(500)

  // Metadata
  reportedBy       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporter         User     @relation("IncidentReporter", fields: [reportedBy], references: [id])

  @@unique([projectId, incidentNumber])
  @@index([tenantId])
  @@index([projectId])
  @@index([projectId, tenantId])
  @@index([status])
  @@index([severity])
  @@index([incidentType])
  @@index([incidentDate])
  @@map("safety_incidents")
}

// ============================================================================
// CHANGE ORDERS (Scope Change Tracking)
// ============================================================================

model ChangeOrder {
  id            String    @id @default(uuid())
  tenantId      String
  projectId     String

  // Identification
  coNumber      String    @db.VarChar(50)  // Auto-generated: CO-001
  title         String    @db.VarChar(255)
  description   String?   @db.Text
  reason        String?   @db.Text  // Justification for the change

  // Status Workflow: draft → submitted → under_review → approved / rejected / void
  status        String    @default("draft") @db.VarChar(50)
  priority      String    @default("medium") @db.VarChar(20)

  // Financial Impact
  estimatedCost Decimal?  @db.Decimal(15, 2)
  approvedCost  Decimal?  @db.Decimal(15, 2)

  // Schedule Impact
  scheduleDays  Int?      // Estimated days of delay/acceleration
  scheduleImpact Boolean  @default(false)

  // Key Dates
  submittedAt   DateTime?
  reviewedAt    DateTime?
  approvedAt    DateTime?
  rejectedAt    DateTime?

  // Approval Chain
  requestedBy   String    // User who created/requested
  approvedById  String?   // User who approved/rejected
  rejectionReason String? @db.Text

  // Reference
  drawingRef    String?   @db.VarChar(255)
  specSection   String?   @db.VarChar(100)

  // Metadata
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requester     User            @relation("ChangeOrderRequester", fields: [requestedBy], references: [id])
  approvedBy    User?           @relation("ChangeOrderApprover", fields: [approvedById], references: [id])
  items         ChangeOrderItem[]

  @@unique([projectId, coNumber])
  @@index([tenantId])
  @@index([projectId])
  @@index([projectId, tenantId])
  @@index([status])
  @@index([requestedBy])
  @@map("change_orders")
}

model ChangeOrderItem {
  id              String    @id @default(uuid())
  changeOrderId   String
  budgetItemId    String?   // Optional link to existing budget item

  // Line Item Details
  category        String    @db.VarChar(100) // labor, materials, equipment, subcontractor, other
  description     String    @db.Text
  quantity        Decimal   @default(1)  @db.Decimal(10, 2)
  unitCost        Decimal   @db.Decimal(15, 2)
  totalCost       Decimal   @db.Decimal(15, 2) // quantity * unitCost
  notes           String?   @db.Text

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  changeOrder     ChangeOrder @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)
  budgetItem      BudgetItem? @relation(fields: [budgetItemId], references: [id])

  @@index([changeOrderId])
  @@index([budgetItemId])
  @@map("change_order_items")
}
